# ─── SecurBookingApp — Variables d'environnement ─────────────────────────────
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ne jamais commiter .env dans le dépôt Git.

# ─── React Native Packager ────────────────────────────────────────────────────
REACT_NATIVE_PACKAGER_HOSTNAME=localhost

# ─── API ──────────────────────────────────────────────────────────────────────
# Android emulator → 10.0.2.2 mappe vers localhost de l'hôte
# iOS simulator   → localhost fonctionne directement
# Production      → URL de l'API déployée
API_BASE_URL_ANDROID=http://10.0.2.2:3000/api/v1
API_BASE_URL_IOS=http://localhost:3000/api/v1
API_BASE_URL_PROD=https://api.securbooking.com/api/v1
API_TIMEOUT_MS=15000

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Clé publique Stripe (pk_test_... ou pk_live_...)
# Ne jamais utiliser la clé secrète côté mobile.
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Sentry (monitoring optionnel) ───────────────────────────────────────────
# SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─── Feature Flags ───────────────────────────────────────────────────────────
# ENABLE_2FA=true
# ENABLE_PUSH_NOTIFICATIONS=true
