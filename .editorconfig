# EditorConfig — enforce UTF-8 (no BOM) so files can never be re-saved as
# CP1252/Latin-1 (the root cause of the mojibake) or with a UTF-8 BOM.
# https://editorconfig.org
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
